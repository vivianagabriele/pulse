{
  "name": "pulse",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@google/genai": "^1.45.0",
    "google-trends-api": "^4.9.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "start": "concurrently --raw \"npm run start-backend\" \"npm run start-frontend\"",
    "start-frontend": "react-app-rewired start",
    "start-backend": "node backend/server.js",
    "build": "react-app-rewired build",
    "test": "react-app-rewired test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "assert": "^2.1.0",
    "autoprefixer": "^10.4.27",
    "buffer": "^6.0.3",
    "concurrently": "^8.2.2",
    "crypto-browserify": "^3.12.1",
    "https-browserify": "^1.0.0",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "postcss": "^8.5.8",
    "process": "^0.11.10",
    "querystring-es3": "^0.2.1",
    "react-app-rewired": "^2.2.1",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "tailwindcss": "^3.4.19",
    "url": "^0.11.4"
  }
}
